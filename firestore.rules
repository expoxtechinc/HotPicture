rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES & HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Bootstrapped Admin: User email luckyglobalnews@gmail.com is authorized as admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token != null && 
             request.auth.token.email == "luckyglobalnews@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ANNOUNCEMENTS RULES ---
    function isValidAnnouncement(data) {
      return data.keys().hasAll(['id', 'title', 'content', 'category', 'publisherEmail', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 150 &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 5000 &&
             data.category is string && data.category.size() >= 1 && data.category.size() <= 50 &&
             data.publisherEmail == "luckyglobalnews@gmail.com" &&
             data.createdAt == request.time;
    }

    match /announcements/{announcementId} {
      // Anyone can browse announcements or list them
      allow read: if true;

      // Only administrators can write announcements
      allow create: if isAdmin() && 
                    isValidId(announcementId) && 
                    announcementId == incoming().id && 
                    isValidAnnouncement(incoming());

      allow update: if isAdmin() && 
                    isValidId(announcementId) && 
                    isValidAnnouncement(incoming());

      allow delete: if isAdmin();
    }

    // --- INQUIRIES RULES ---
    function isValidInquiry(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'subject', 'message', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.email is string && data.email.size() >= 1 && data.email.size() <= 100 &&
             data.subject is string && data.subject.size() >= 1 && data.subject.size() <= 200 &&
             data.message is string && data.message.size() >= 1 && data.message.size() <= 2000 &&
             data.status in ['unread', 'replied', 'dismissed'] &&
             data.createdAt == request.time;
    }

    match /inquiries/{inquiryId} {
      // Parents can submit inquiries without being signed in (public write access)
      allow create: if isValidId(inquiryId) && 
                    inquiryId == incoming().id && 
                    isValidInquiry(incoming());

      // Only authenticated admins can read, list, update or delete student queries and interest messages
      allow read, update, delete: if isAdmin();
    }
  }
}
